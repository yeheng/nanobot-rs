# =============================================================================
# gasket Channel E2E Test Environment Variables
# Copy this file to .env and fill in real values to run E2E tests
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Discord ---
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CHANNEL_ID=C0123456789

# --- Email (SMTP/IMAP) ---
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=your-email@example.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=your-email@example.com
EMAIL_IMAP_PASSWORD=your-app-password
EMAIL_FROM_ADDRESS=your-email@example.com
EMAIL_TO_ADDRESS=recipient@example.com

# --- DingTalk ---
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=SECyour-secret

# --- Feishu ---
FEISHU_APP_ID=cli_your_app_id
FEISHU_APP_SECRET=your-app-secret
FEISHU_CHAT_ID=oc_your-chat-id

# --- WeCom (企业微信) ---
WECOM_CORP_ID=your-corp-id
WECOM_CORP_SECRET=your-corp-secret
WECOM_AGENT_ID=1000002
WECOM_TOKEN=your-callback-token
WECOM_ENCODING_AES_KEY=your-43-char-encoding-aes-key
WECOM_TO_USER=UserID1
